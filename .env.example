# Copy to .env and fill in. docker-compose reads this file.

# Shared API key the Flutter client must send as X-API-Key on every request.
# Generate a long random value, e.g. `openssl rand -hex 32`.
HAR_API_KEY=change-me-to-a-long-random-string

# Postgres credentials. docker-compose uses these for both the db service
# and the api service (DATABASE_URL is derived from them in compose).
POSTGRES_DB=har
POSTGRES_USER=har
POSTGRES_PASSWORD=har-dev-password

# Maximum compressed upload size in bytes. Default 50 MiB.
HAR_MAX_UPLOAD_BYTES=52428800

# Port the API binds on the host.
HAR_API_PORT=8000
